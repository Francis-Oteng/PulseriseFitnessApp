# Pulserise Fitness App Environment Configuration
# Copy this file to .env and fill in your actual values

# API Configuration
EXPO_PUBLIC_API_BASE_URL=https://api.pulserise.app
EXPO_PUBLIC_API_TIMEOUT=10000

# Pexels API for workout images
EXPO_PUBLIC_PEXELS_API_KEY=your_pexels_api_key_here

# Google OAuth
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here
