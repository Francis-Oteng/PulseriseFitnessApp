# Pulserise Fitness App Environment Configuration
# Copy this file to .env and fill in your actual values

# API Configuration
EXPO_PUBLIC_API_BASE_URL=https://api.pulserise.app
EXPO_PUBLIC_API_TIMEOUT=10000

# Pexels API for workout images
# Get your key at: https://www.pexels.com/api/
EXPO_PUBLIC_PEXELS_API_KEY=your_pexels_api_key_here

# Google OAuth
# Get from Google Cloud Console > APIs & Services > Credentials
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here

# EAS Project ID
# Run `eas init` to generate, then update app.config.js extra.eas.projectId
# EAS_PROJECT_ID=your-eas-project-id

# Google Sign-In iOS URL Scheme
# Found in your GoogleService-Info.plist as REVERSED_CLIENT_ID
# Update app.config.js plugins[@react-native-google-signin/google-signin].iosUrlScheme
# GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.YOUR_CLIENT_ID
